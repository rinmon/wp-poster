# WordPress REST API
# このファイルを .env にコピーし、実際の値を記入してください。
# .env は .gitignore で除外され、GitHub に含まれません。
#
WP_API_URL=https://example.com/wp-json/wp/v2
WP_USER=your_username
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# タイトル重複: 未設定＝search のみ（既定・高速）。専用 REST を導入したサイトだけ次を有効化
# API_POSTER_USE_CUSTOM_CHECK_TITLE=1
# REST search の取りこぼし対策: 直近の更新順に最大 N ページ（100 件/ページ）を正規化タイトルで走査。既定 3。0 で無効
# API_POSTER_DUP_RECENT_SCAN_PAGES=3
# タイトル検索の最大ページ数（1〜5、既定 3）
# API_POSTER_TITLE_SEARCH_MAX_PAGES=3
# タイトル・タグ・抜粋の類似度閾値（duplicate_hints / check_article_duplicates と共通）
# DUP_HINT_THRESHOLD=0.74

# サーバー診断用（check_server_health.py, wp_version_snapshot.py）
# SSH_HOST=your-server-ip
# SSH_USER=ssh_username
# SSH_PASS=ssh_password
# WP_PATH=/var/www/example.com
